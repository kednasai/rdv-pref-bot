# Copy this file to `.env` and fill in your values.
# Do NOT commit your real .env — it's in .gitignore.

# DeathByCaptcha account credentials.
# Sign up at https://www.deathbycaptcha.com/
DBC_USERNAME=your_dbc_username
DBC_PASSWORD=your_dbc_password

# Target booking URL. The path after /demarche/ identifies the specific
# procedure at the target prefecture. Check your own prefecture's URL.
RDV_URL=https://www.rdv-prefecture.interieur.gouv.fr/rdvpref/reservation/demarche/9040/

# Chrome major version installed on this machine.
# Check with: google-chrome --version   OR   chromium --version
CHROME_VERSION_MAIN=140

# Path to the alarm sound file (any format paplay can handle).
ALARM_FILE=alarm.mp3
